{
  "name": "halftone-light",
  "version": "1.0.0",
  "description": "GPU-accelerated halftone effect with OGL — lightweight, Webflow-friendly",
  "author": "adar2378",
  "license": "MIT",
  "main": "dist/halftone-light.min.js",
  "module": "dist/halftone-light.esm.js",
  "exports": {
    ".": {
      "import": "./dist/halftone-light.esm.js",
      "default": "./dist/halftone-light.min.js"
